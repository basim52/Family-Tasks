{
  "entities": {
    "User": {
      "title": "User",
      "description": "Family member profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["parent", "child"] },
        "points": { "type": "number" },
        "currencyBalance": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "role", "points"]
    },
    "Task": {
      "title": "Task",
      "description": "Household chore assigned to a child",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "points": { "type": "number" },
        "startTime": { "type": "string", "description": "e.g., 09:00" },
        "endTime": { "type": "string", "description": "e.g., 10:00" },
        "status": { "type": "string", "enum": ["pending", "completed", "approved"] },
        "assignedTo": { "type": "string" },
        "createdBy": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "points", "status", "createdBy"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Points redemption or reward",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["earn", "redeem"] },
        "points": { "type": "number" },
        "currencyAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "requestedAt": { "type": "string", "format": "date-time" },
        "processedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "points", "status"]
    },
    "Message": {
      "title": "Message",
      "description": "Chat message in family group",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "image", "audio", "video_call"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "content", "type", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "In-app alerts",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "type": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "read", "createdAt"]
    },
    "Prize": {
      "title": "Prize",
      "description": "Family rewards",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "cost": { "type": "number" },
        "imageUrl": { "type": "string" }
      },
      "required": ["title", "cost"]
    },
    "Config": {
      "title": "Config",
      "description": "Family settings",
      "type": "object",
      "properties": {
        "pointExchangeRate": { "type": "number" },
        "familyLevels": { "type": "object" }
      }
    },
    "BigGoal": {
      "title": "Big Goal",
      "description": "A long-term target for points",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "targetPoints": { "type": "number" },
        "userId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "targetPoints", "userId", "status"]
    },
    "MonthlyReward": {
      "title": "Monthly Reward",
      "description": "Special monthly prizes",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "cost": { "type": "number" },
        "month": { "type": "string", "description": "e.g., 2026-05" },
        "description": { "type": "string" },
        "claimedBy": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "cost", "month"]
    },
    "Call": {
      "title": "Call",
      "description": "Family video/voice call",
      "type": "object",
      "properties": {
        "hostId": { "type": "string" },
        "hostName": { "type": "string" },
        "hostPhoto": { "type": "string" },
        "type": { "type": "string", "enum": ["video", "voice"] },
        "status": { "type": "string", "enum": ["active", "ended"] },
        "participants": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["hostId", "type", "status", "createdAt"]
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "Store family member details"
    },
    "tasks": {
      "schema": "Task",
      "description": "Chore tracking"
    },
    "transactions": {
      "schema": "Transaction",
      "description": "Wallet history"
    },
    "messages": {
      "schema": "Message",
      "description": "Family chat history"
    },
    "notifications": {
      "schema": "Notification",
      "description": "User alerts"
    },
    "prizes": {
      "schema": "Prize",
      "description": "Rewards shop"
    },
    "config": {
      "schema": "Config",
      "description": "Global settings"
    },
    "bigGoals": {
      "schema": "BigGoal",
      "description": "Long-term goals for children"
    },
    "monthlyRewards": {
      "schema": "MonthlyReward",
      "description": "Monthly special prizes"
    },
    "calls": {
      "schema": "Call",
      "description": "Family calls"
    }
  }
}
