{
  "entities": {
    "User": {
      "title": "User",
      "description": "Family member profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["parent", "child"] },
        "points": { "type": "number" },
        "currencyBalance": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "role", "points"]
    },
    "Task": {
      "title": "Task",
      "description": "Household chore assigned to a child",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "points": { "type": "number" },
        "startTime": { "type": "string", "description": "e.g., 09:00" },
        "endTime": { "type": "string", "description": "e.g., 10:00" },
        "status": { "type": "string", "enum": ["pending", "completed", "approved"] },
        "assignedTo": { "type": "string" },
        "createdBy": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "points", "status", "createdBy"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Points redemption or reward",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["earn", "redeem"] },
        "points": { "type": "number" },
        "currencyAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "requestedAt": { "type": "string", "format": "date-time" },
        "processedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "points", "status"]
    },
    "Message": {
      "title": "Message",
      "description": "Chat message in family group",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "image", "audio", "video_call"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "content", "type", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "In-app alerts",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "type": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "read", "createdAt"]
    },
    "Prize": {
      "title": "Prize",
      "description": "Family rewards",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "cost": { "type": "number" },
        "imageUrl": { "type": "string" }
      },
      "required": ["title", "cost"]
    },
    "Config": {
      "title": "Config",
      "description": "Family settings",
      "type": "object",
      "properties": {
        "pointExchangeRate": { "type": "number" },
        "familyLevels": { "type": "object" }
      }
    },
    "BigGoal": {
      "title": "Big Goal",
      "description": "A long-term target for points",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "targetPoints": { "type": "number" },
        "userId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "targetPoints", "userId", "status"]
    },
    "MonthlyReward": {
      "title": "Monthly Reward",
      "description": "Special monthly prizes",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "cost": { "type": "number" },
        "month": { "type": "string", "description": "e.g., 2026-05" },
        "description": { "type": "string" },
        "claimedBy": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "cost", "month"]
    },
    "Call": {
      "title": "Call",
      "description": "Family video/voice call",
      "type": "object",
      "properties": {
        "hostId": { "type": "string" },
        "hostName": { "type": "string" },
        "hostPhoto": { "type": "string" },
        "type": { "type": "string", "enum": ["video", "voice"] },
        "status": { "type": "string", "enum": ["active", "ended"] },
        "participants": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["hostId", "type", "status", "createdAt"]
    },
    "BehaviorRating": {
      "title": "Behavior Rating",
      "description": "Weekly assessment of child behavior",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "points": { "type": "number", "description": "Positive for plus, negative for minusPoints" },
        "reason": { "type": "string" },
        "evaluatorId": { "type": "string" },
        "evaluatorName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "points", "reason", "evaluatorId", "createdAt"]
    },
    "Motivation": {
      "title": "Motivation",
      "description": "Positive messages to family members",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "receiverId": { "type": "string" },
        "userName": { "type": "string" },
        "message": { "type": "string" },
        "icon": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "receiverId", "message", "createdAt"]
    },
    "MotivationTemplate": {
      "title": "Motivation Template",
      "description": "Predefined motivation messages",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["content"]
    },
    "Cheque": {
      "title": "Cheque",
      "description": "Financial document for cash redemption",
      "type": "object",
      "properties": {
        "transactionId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "issuedAt": { "type": "string", "format": "date-time" },
        "issuedBy": { "type": "string" },
        "issuedByName": { "type": "string" },
        "serialNumber": { "type": "string" }
      },
      "required": ["transactionId", "userId", "amount", "issuedAt", "serialNumber"]
    },
    "Badge": {
      "title": "Badge",
      "description": "Achievement badge awarded to a child",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "childId": { "type": "string" },
        "childName": { "type": "string" },
        "icon": { "type": "string" },
        "color": { "type": "string" },
        "awardedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "childId", "childName", "icon", "color", "awardedAt"]
    },
    "SilenceSession": {
      "title": "Silence Session",
      "description": "A recorded moment of family silence/calm",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "phrase": { "type": "string" },
        "recorderId": { "type": "string" },
        "recorderName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "phrase", "recorderId", "recorderName", "createdAt"]
    },
    "DevelopmentPlan": {
      "title": "Development Plan",
      "description": "A personal growth/development roadmap with milestones built by parents for children",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "assignedTo": { "type": "string" },
        "assignedToName": { "type": "string" },
        "creatorId": { "type": "string" },
        "creatorName": { "type": "string" },
        "rewardCoins": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "completed"] },
        "milestones": {
          "type": "array",
          "items": { "type": "object" }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "assignedTo", "assignedToName", "creatorId", "rewardCoins", "status", "milestones", "createdAt"]
    },
    "DailyTask": {
      "title": "Daily Task",
      "description": "A personal self-organized daily task with time, date and tick-mark completion",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "endTime": { "type": "string" },
        "points": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed", "expired"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" },
        "category": { "type": "string" },
        "isArchived": { "type": "boolean" }
      },
      "required": ["title", "userId", "date", "time", "endTime", "status", "createdAt"]
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "Store family member details"
    },
    "tasks": {
      "schema": "Task",
      "description": "Chore tracking"
    },
    "transactions": {
      "schema": "Transaction",
      "description": "Wallet history"
    },
    "messages": {
      "schema": "Message",
      "description": "Family chat history"
    },
    "notifications": {
      "schema": "Notification",
      "description": "User alerts"
    },
    "prizes": {
      "schema": "Prize",
      "description": "Rewards shop"
    },
    "config": {
      "schema": "Config",
      "description": "Global settings"
    },
    "bigGoals": {
      "schema": "BigGoal",
      "description": "Long-term goals for children"
    },
    "monthlyRewards": {
      "schema": "MonthlyReward",
      "description": "Monthly special prizes"
    },
    "calls": {
      "schema": "Call",
      "description": "Family calls"
    },
    "behaviorRatings": {
      "schema": "BehaviorRating",
      "description": "Weekly behavioral points"
    },
    "motivations": {
      "schema": "Motivation",
      "description": "Positive message history"
    },
    "motivationTemplates": {
      "schema": "MotivationTemplate",
      "description": "Ready-made message templates"
    },
    "cheques": {
      "schema": "Cheque",
      "description": "Financial cheques for points redemption"
    },
    "badges": {
      "schema": "Badge",
      "description": "Achievement badges awarded to children"
    },
    "silenceSessions": {
      "schema": "SilenceSession",
      "description": "Recording of family calm moments"
    },
    "developmentPlans": {
      "schema": "DevelopmentPlan",
      "description": "Custom educational and behavior growth roadmaps built by parents for children"
    },
    "dailyTasks": {
      "schema": "DailyTask",
      "description": "Self-authored daily tasks"
    }
  }
}
