rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function isParent() {
      return isSignedIn() && (
        request.auth.token.email == 'basim5252@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'parent')
      );
    }

    function isChild() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'child';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Entity Validations
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'role', 'points']) 
        && data.uid == request.auth.uid
        && data.role in ['parent', 'child']
        && data.points is number
        && data.points >= 0;
    }

    function isValidTask(data) {
      return data.keys().hasAll(['title', 'points', 'status', 'createdBy'])
        && data.title is string && data.title.size() <= 200
        && data.points is number && data.points >= 0
        && data.status in ['pending', 'completed', 'approved']
        && (!data.keys().contains('startTime') || (data.startTime is string && data.startTime.size() <= 20))
        && (!data.keys().contains('endTime') || (data.endTime is string && data.endTime.size() <= 20));
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['userId', 'type', 'points', 'status'])
        && data.userId == request.auth.uid
        && data.type in ['earn', 'redeem', 'prize_purchase']
        && data.points is number && data.points >= 0;
        // status check handled in allows
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['senderId', 'content', 'type', 'createdAt'])
        && data.senderId == request.auth.uid
        && data.content is string && data.content.size() <= 5000
        && data.type in ['text', 'image', 'audio', 'video_call']
        && data.createdAt == request.time;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'title', 'body', 'read', 'createdAt', 'type'])
        && data.userId is string
        && data.title is string && data.title.size() <= 200
        && data.read == false
        && data.createdAt == request.time;
    }

    function isValidPrize(data) {
      return data.keys().hasAll(['title', 'cost', 'createdAt'])
        && data.title is string && data.title.size() <= 200
        && data.cost is number && data.cost >= 0;
    }

    function isValidBigGoal(data) {
      return data.keys().hasAll(['title', 'targetPoints', 'userId', 'status'])
        && data.title is string && data.title.size() <= 200
        && data.targetPoints is number && data.targetPoints >= 0
        && data.userId is string
        && data.status in ['active', 'completed'];
    }

    function isValidMonthlyReward(data) {
      return data.keys().hasAll(['title', 'cost', 'month', 'createdAt'])
        && data.title is string && data.title.size() <= 200
        && data.cost is number && data.cost >= 0
        && data.month is string
        && data.createdAt == request.time;
    }

    function isValidCall(data) {
      return data.keys().hasAll(['hostId', 'type', 'status', 'createdAt'])
        && data.hostId == request.auth.uid
        && data.type in ['video', 'voice']
        && data.status in ['active', 'ended']
        && data.createdAt == request.time;
    }

    function isValidBehaviorRating(data) {
      return data.keys().hasAll(['userId', 'points', 'reason', 'evaluatorId', 'createdAt'])
        && data.evaluatorId == request.auth.uid
        && data.userId is string
        && data.points is number
        && data.reason is string && data.reason.size() <= 1000
        && data.createdAt == request.time;
    }

    function isValidMotivation(data) {
      return data.keys().hasAll(['senderId', 'receiverId', 'message', 'createdAt'])
        && data.senderId == request.auth.uid
        && data.receiverId is string
        && data.message is string && data.message.size() <= 1000
        && data.createdAt == request.time;
    }

    function isValidMotivationTemplate(data) {
      return data.keys().hasAll(['content'])
        && data.content is string && data.content.size() <= 1000;
    }

    function isValidCheque(data) {
      return data.keys().hasAll(['transactionId', 'userId', 'amount', 'issuedAt', 'serialNumber'])
        && data.transactionId is string
        && data.userId is string
        && data.amount is number
        && data.issuedAt == request.time;
    }

    // Collection Rules

    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isUser(userId) && isValidUser(request.resource.data);
      allow update: if (isUser(userId) && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'photoURL']) ||
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['points']) && request.resource.data.points < resource.data.points)
        ))
        || isParent();
    }

    match /tasks/{taskId} {
      allow get, list: if isSignedIn();
      allow create: if isParent() && isValidTask(request.resource.data);
      allow update: if isParent() 
        || (isSignedIn() && resource.data.assignedTo == request.auth.uid 
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'completedAt', 'completedImageUrl'])
            && (request.resource.data.status == 'completed' || request.resource.data.status == 'pending'));
      allow delete: if isParent();
      
      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isParent());
      }
    }

    match /transactions/{transactionId} {
      allow get, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isParent());
      allow create: if isSignedIn() && isValidTransaction(request.resource.data) && (
        request.resource.data.status == 'pending' ||
        (isChild() && (request.resource.data.type == 'redeem' || request.resource.data.type == 'prize_purchase') && request.resource.data.status == 'approved')
      );
      allow update: if isParent();
    }

    match /messages/{messageId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && isValidMessage(request.resource.data);
    }

    match /notifications/{notifId} {
      allow get, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isParent());
      allow create: if isSignedIn() && isValidNotification(request.resource.data);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isParent();
    }

    match /prizes/{prizeId} {
      allow get, list: if isSignedIn();
      allow create: if isParent() && isValidPrize(request.resource.data);
      allow update: if isParent();
      allow delete: if isParent();
    }

    match /config/{configId} {
      allow get, list: if isSignedIn();
      allow write: if isParent();
    }

    match /bigGoals/{goalId} {
      allow read: if isSignedIn() && (isParent() || resource.data.userId == request.auth.uid);
      allow create: if isParent() && isValidBigGoal(request.resource.data);
      allow update: if isParent();
      allow delete: if isParent();
    }

    match /monthlyRewards/{rewardId} {
      allow read: if isSignedIn();
      allow create: if isParent() && isValidMonthlyReward(request.resource.data);
      allow update: if isParent() || (isChild() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['claimedBy']));
      allow delete: if isParent();
    }

    match /calls/{callId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && isValidCall(request.resource.data);
      allow update: if isSignedIn() && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participants', 'status'])
      );
      allow delete: if isSignedIn() && resource.data.hostId == request.auth.uid;
    }

    match /behaviorRatings/{ratingId} {
      allow get, list: if isSignedIn();
      allow create: if isParent() && isValidBehaviorRating(request.resource.data);
      allow delete: if isParent();
    }

    match /motivations/{motivationId} {
      allow get, list: if isSignedIn();
      allow create: if isParent() && isValidMotivation(request.resource.data);
      allow delete: if isParent();
    }

    match /motivationTemplates/{templateId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isParent() && isValidMotivationTemplate(request.resource.data);
    }

    match /cheques/{chequeId} {
      allow get, list: if isSignedIn();
      allow create: if isParent() && isValidCheque(request.resource.data);
      allow delete: if isParent();
    }
  }
}
